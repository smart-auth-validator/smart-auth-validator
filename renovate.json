{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],

  "dependencyDashboard": true,
  "dependencyDashboardAutoclose": true,

  "osvVulnerabilityAlerts": true,

  "vulnerabilityAlerts": {
    "enabled": true,
    "automerge": true,
    "automergeType": "pr",
    "automergeStrategy": "squash",
    "labels": ["security", "renovate"],
    "prPriority": 10,
    "schedule": ["at any time"]
  },

  "packageRules": [
    {
      "description": "SECURITY: Fix minimatch ReDoS - issues #15 #16 #18",
      "matchPackageNames": ["minimatch"],
      "allowedVersions": ">=9.0.6",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "schedule": ["at any time"],
      "labels": ["security", "renovate"]
    },
    {
      "description": "SECURITY: Fix rollup Directory Traversal - issue #17",
      "matchPackageNames": ["rollup"],
      "allowedVersions": ">=3.29.5",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "schedule": ["at any time"],
      "labels": ["security", "renovate"]
    },
    {
      "description": "SECURITY: Fix flatted Recursion - issue #14",
      "matchPackageNames": ["flatted"],
      "allowedVersions": ">=3.3.2",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "schedule": ["at any time"],
      "labels": ["security", "renovate"]
    },
    {
      "description": "SECURITY: Fix fastify ReDoS - issue #13",
      "matchPackageNames": ["fastify"],
      "allowedVersions": ">=4.26.2",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "schedule": ["at any time"],
      "labels": ["security", "renovate"]
    },
    {
      "description": "Auto-merge GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "GitHub Actions",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Auto-merge devDependencies minor/patch",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Dev Dependencies",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    }
  ],

  "npm": { "enabled": true },
  "github-actions": { "enabled": true },
  "schedule": ["at any time"],
  "timezone": "Asia/Karachi",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "rebaseWhen": "conflicted",
  "labels": ["renovate", "dependencies"],
  "platformAutomerge": true
}
